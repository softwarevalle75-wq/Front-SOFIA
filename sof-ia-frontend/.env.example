# URL del backend (SOFIA-AUTH + SICOP)
VITE_API_URL=http://localhost:3000/api

# URL del chatbot de WhatsApp (opcional - para cuando lo implementemos)
VITE_CHATBOT_URL=https://web.whatsapp.com

# URL del bot de Telegram
VITE_TELEGRAM_BOT_URL=https://t.me/ValleSoftwareBot

# URL publica compartible del chatbot
VITE_PUBLIC_CHATBOT_URL=https://sofia-developed.up.railway.app/chatbot

# Modo backend chatbot (unico modo soportado)
VITE_CHATBOT_BACKEND_MODE=sicop_proxy

# Opcional solo para compatibilidad del payload webchat
VITE_WEBCHAT_TENANT_ID=tenant_ai_demo

# Si es true, el frontend expone solo /chatbot y redirige cualquier otra ruta a /chatbot
VITE_PUBLIC_CHATBOT_ONLY=false
